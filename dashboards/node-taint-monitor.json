{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Monitor node resource consumption filtered by Kubernetes node taints",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Nodes with taint  key=$taint_key  value=$taint_value  effect=$taint_effect",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "CPU Usage",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (node) (\n  1 - rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node_instance\"}[$__rate_interval])\n)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Memory Usage",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  node_memory_MemAvailable_bytes{instance=~\"$node_instance\"}\n  /\n  node_memory_MemTotal_bytes{instance=~\"$node_instance\"}\n)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Disk Usage",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  sum by (instance) (node_filesystem_avail_bytes{instance=~\"$node_instance\",mountpoint=\"/\",fstype!=\"tmpfs\"})\n  /\n  sum by (instance) (node_filesystem_size_bytes{instance=~\"$node_instance\",mountpoint=\"/\",fstype!=\"tmpfs\"})\n)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Pod Capacity Used",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (node) (kube_pod_info{node=~\"$tainted_nodes\"})\n/\nsum by (node) (kube_node_status_capacity{node=~\"$tainted_nodes\",resource=\"pods\"})",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "CPU & Memory Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node_instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - (\n  node_memory_MemAvailable_bytes{instance=~\"$node_instance\"}\n  /\n  node_memory_MemTotal_bytes{instance=~\"$node_instance\"}\n)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Taint Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "node" }, "properties": [{ "id": "displayName", "value": "Node" }] },
          { "matcher": { "id": "byName", "options": "key" }, "properties": [{ "id": "displayName", "value": "Taint Key" }] },
          { "matcher": { "id": "byName", "options": "value" }, "properties": [{ "id": "displayName", "value": "Taint Value" }] },
          { "matcher": { "id": "byName", "options": "effect" }, "properties": [{ "id": "displayName", "value": "Effect" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 7,
      "options": {
        "footer": { "enablePagination": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Node" }]
      },
      "title": "All Node Taints",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "rows", "valueLabel": "node" } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "kube_node_spec_taint",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "color-background" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 8,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "title": "Resource Summary — Nodes with taint $taint_key=$taint_value",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "node": "Node",
              "Value #CPU": "CPU %",
              "Value #MEM": "Memory %",
              "Value #PODS": "Pod Capacity %"
            }
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(\n  (1 - rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node_instance\"}[$__rate_interval]))\n  * 100, 0.01\n)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "CPU"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(\n  (1 - node_memory_MemAvailable_bytes{instance=~\"$node_instance\"} / node_memory_MemTotal_bytes{instance=~\"$node_instance\"})\n  * 100, 0.01\n)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{instance}}",
          "refId": "MEM"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["kubernetes", "nodes", "taints"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_node_spec_taint, key)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "taint_key",
        "query": {
          "query": "label_values(kube_node_spec_taint, key)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Taint Key"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_node_spec_taint{key=\"$taint_key\"}, value)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "taint_value",
        "query": {
          "query": "label_values(kube_node_spec_taint{key=\"$taint_key\"}, value)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Taint Value"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_node_spec_taint{key=\"$taint_key\",value=\"$taint_value\"}, effect)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "taint_effect",
        "query": {
          "query": "label_values(kube_node_spec_taint{key=\"$taint_key\",value=\"$taint_value\"}, effect)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Effect"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kube_node_spec_taint{key=\"$taint_key\",value=\"$taint_value\"}, node)",
        "hide": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "tainted_nodes",
        "query": {
          "query": "label_values(kube_node_spec_taint{key=\"$taint_key\",value=\"$taint_value\"}, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Tainted Nodes (hidden)"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(node_uname_info{nodename=~\"$tainted_nodes\"}, instance)",
        "hide": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "node_instance",
        "query": {
          "query": "label_values(node_uname_info{nodename=~\"$tainted_nodes\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Node Instances (hidden)"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Node Taint Monitor",
  "uid": "node-taint-monitor",
  "version": 1
}
